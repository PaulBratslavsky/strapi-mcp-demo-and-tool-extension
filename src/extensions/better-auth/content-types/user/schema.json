{
  "kind": "collectionType",
  "collectionName": "ba_user",
  "info": {
    "singularName": "user",
    "pluralName": "users",
    "displayName": "Users"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "name": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true
    },
    "email": {
      "type": "email",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "unique": true
    },
    "emailVerified": {
      "type": "boolean",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      },
      "required": true,
      "default": false
    },
    "image": {
      "type": "text",
      "configurable": false,
      "pluginOptions": {
        "better-auth": {
          "managed": true
        }
      }
    }
  }
}
